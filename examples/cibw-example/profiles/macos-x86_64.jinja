include(default)

[settings]
arch=x86_64
os.version=11.0

[tool_requires]
cmake/[>3.29]

[buildenv]
MACOSX_DEPLOYMENT_TARGET=11.0
# Cross build: the running interpreter is arm64, so its auto-detected platform tag
# would be wrong. Pin the wheel's platform tag to the x86_64 target. (pyver/abi are
# still auto-detected correctly from the interpreter cibuildwheel provides.)
WHEEL_ARCH=macosx_11_0_x86_64
